  },
  "dependencies": {
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "archiver": "^7.0.1",
    "argon2": "^0.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.35.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "file-type": "^22.0.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jose": "^5.6.0",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.0"
