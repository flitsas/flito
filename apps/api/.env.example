# Plantilla de variables de entorno — operaciones-system API.
# Copiar a `.env` y completar valores. NUNCA commitear `.env`.

# Entorno
NODE_ENV=development
PORT=3005

# Base de datos PostgreSQL (operaciones_db). Usuario operaciones_app, NO postgres (WORM rndc).
DATABASE_URL=postgresql://operaciones_app:CAMBIAR_PASSWORD@localhost:5432/operaciones_db

# JWT (mín 32 caracteres). Generar con: `openssl rand -hex 48`.
JWT_SECRET=GENERAR_NUEVO_AL_DEPLOYAR_MIN_32_CHARS

# Clave HMAC dedicada para tokens de descarga pública (drive procesador).
# Si no se define, se usa JWT_SECRET (compatible con tokens distribuidos).
# Recomendado: definir clave independiente para que rotar JWT no rompa Excels distribuidos.
# Generar con: `openssl rand -hex 32`.
DOWNLOAD_TOKEN_SECRET=

# CORS. Dev local: '*'. Producción: lista comma-separated de URLs https.
# El boot falla si NODE_ENV=production y CORS_ORIGIN incluye '*'.
CORS_ORIGIN=http://localhost:5173

# Anthropic (opcional para módulos OCR/IA). Compartida con CEA / Catastro.
ANTHROPIC_API_KEY=sk-ant-...
# FLOTA-03: modelos OCR configurables (con default). Cambiar SIN redeploy si
# Anthropic deprecate un snapshot (causa raíz INC-OCR-2026-05-12). En blanco = default.
ANTHROPIC_MODEL_HAIKU=
ANTHROPIC_MODEL_SONNET=

# RUNT consultas (mín 20 chars). Coordinar con equipo CEA.
RUNT_INTERNAL_KEY=GENERAR_AL_DEPLOYAR_MIN_20_CHARS

# Cifrado PII general (mín 32 chars). Generar con: `openssl rand -hex 32`.
PII_ENC_KEY=GENERAR_AL_DEPLOYAR_MIN_32_CHARS

# HMAC determinístico para búsqueda de cédula (64 hex = 32 bytes). OBLIGATORIO:
# el boot falla si falta. Separado de PII_ENC_KEY por mínimo privilegio (ISO A.9.4).
# Generar con: `openssl rand -hex 32`.
PII_HMAC_KEY=GENERAR_AL_DEPLOYAR_64_HEX_CHARS

# RNDC (Sprint 4 Fase 4.2): clave AES-256-GCM (64 hex = 32 bytes).
# Generar con: `openssl rand -hex 32`. En dev se deriva de PII_ENC_KEY si falta.
RNDC_ENC_KEY=
RNDC_MODE=mock
RNDC_MOCK_ERROR_RATE=0
RNDC_MOCK_TIMEOUT_RATE=0.02
# OPS-08: NIT empresa emisora RNDC (6-12 dígitos). Default 900000001.
EMPRESA_NIT=900000001
# OPS-08: ambiente del envío SOAP RNDC. sandbox | produccion. Default sandbox.
RNDC_AMBIENTE=sandbox

# SMTP (notificaciones operativas). Office 365 o equivalente.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=info@kyverum.com
SMTP_PASS=
SMTP_FROM_NAME=FLIT Operaciones

# URLs públicas
PUBLIC_URL=http://localhost:5173

# MinIO / S3 (almacenamiento de evidencias)
S3_ENDPOINT=s3.kyverum.com
S3_PORT=443
S3_ACCESS_KEY=GENERAR_USUARIO_MINIO
S3_SECRET_KEY=GENERAR_PASS_MINIO

# Google Drive (cuenta de servicio JSON + ID carpeta raíz compartida con esa cuenta)
# Prod NL ejemplo: GOOGLE_DRIVE_KEY_PATH=/var/www/operaciones/service-account.json
GOOGLE_DRIVE_KEY_PATH=
GOOGLE_DRIVE_FOLDER_ID=

# Redis (lockout login distribuido + rate limiting + JWT blacklist).
# Si no se define, default redis://127.0.0.1:6379. EN PRODUCCIÓN ES OBLIGATORIO Redis activo.
REDIS_URL=redis://127.0.0.1:6379

# Destinatarios alertas PESV (alcoholimetría positiva, etc.). Coma-separados.
# Vacío → fallback a admins activos del tenant. NUNCA dejar emails @kyverum.com aquí.
PESV_ALERT_RECIPIENTS=

# Destinatarios alertas SLA LAFT/ROS (warn_12h, warn_4h, breach). Coma-separados.
# Vacío (opt-in deliberado) → el cron registra la alarma sin destinatarios, no falla.
LAFT_COMPLIANCE_RECIPIENTS=

# --- TRAM-INNOV (opcionales; con default en env.ts — sync OPS-06 PREP) ---
# Notificaciones de estado por WhatsApp (Meta Cloud API). Sin ambas → canal off
# (degradación a email/enlace manual). NO commitear valores reales.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Bloquear "Enviar a tránsito" si faltan obligatorios del checklist. Default true.
# (en blanco = true; poner 'false' para desactivar)
TRAMITE_STRICT_CHECKLIST=
# Si el email de validación de identidad falla, devolver enlace manual en vez de
# bloquear. Default true. (en blanco = true; 'false' para desactivar)
TRAMITES_EMAIL_FALLBACK=
# TRAM-COMMS-02: cron de recordatorios a participantes del portal (09:00 UTC).
# Default OFF. Poner '1' SOLO en prod cuando SMTP (y/o WhatsApp) esté configurado.
TRAM_PORTAL_REMINDER_CRON_ENABLED=
# OPS-08: cron de retención/anonimización PII (Ley 1581 / ISO A.8.10). Default OFF.
# Poner '1' SOLO tras validar P0-NEG-3/4 estables 48h en prod.
PRIVACY_RETENTION_CRON_ENABLED=
# TRAM-INNOV-B3: firma electrónica de compraventa. mock (default) | zapsign.
FIRMA_PROVIDER=mock
# Secreto HMAC para validar webhooks de firma (requerido en prod con zapsign).
FIRMA_WEBHOOK_SECRET=
# Token API ZapSign (solo si FIRMA_PROVIDER=zapsign). Sandbox por defecto.
ZAPSIGN_API_TOKEN=
ZAPSIGN_SANDBOX=true
