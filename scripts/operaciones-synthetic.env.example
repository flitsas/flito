# Copiar en el VPS como /etc/operaciones-synthetic.env (chmod 600)
# Cargado por scripts/synthetic-check.sh

BASE_URL=https://operaciones.flitsas.com

# Email (usa SMTP de /var/www/operaciones/apps/api/.env)
SYNTHETIC_ALERT_EMAIL=info@kyverum.com
# Mínimo entre alertas repetidas (minutos)
SYNTHETIC_ALERT_COOLDOWN_MIN=30

# Slack incoming webhook (opcional — descomentar y pegar URL)
# SYNTHETIC_ALERT_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# Ruta alternativa al .env de la API
# OPERACIONES_ENV_FILE=/var/www/operaciones/apps/api/.env
